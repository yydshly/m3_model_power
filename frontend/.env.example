# MiniMax Workbench — Frontend environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is not committed to git.

# API base URL for the backend server.
# Default: http://127.0.0.1:8777 (matches local backend `python -m uvicorn app.main:app --port 8777`)
VITE_API_BASE_URL=http://127.0.0.1:8777
