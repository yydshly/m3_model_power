{
  "schema_version": 1,
  "templates": {
    "lyrics-gen": {
      "capability_id": "lyrics-gen",
      "label": "歌词生成",
      "description": "根据主题、风格、情绪生成结构化歌词，可继续用于 music-gen。",
      "suitable_for": ["情绪 MV", "AI 歌曲草稿", "短视频 BGM", "音乐灵感"],
      "risk_level": "safe",
      "result_type": "text",
      "form_schema": {
        "theme": {
          "type": "input",
          "label": "主题",
          "default": "夏天傍晚的乡村小路",
          "placeholder": "描述想要的歌曲主题"
        },
        "style": {
          "type": "input",
          "label": "风格",
          "default": "温柔、怀旧、民谣",
          "placeholder": "如：流行、摇滚、温柔、怀旧"
        },
        "language": {
          "type": "select",
          "label": "语言",
          "default": "中文",
          "options": [
            {"value": "中文", "label": "中文"},
            {"value": "英文", "label": "英文"},
            {"value": "日文", "label": "日文"},
            {"value": "韩文", "label": "韩文"},
            {"value": "其他", "label": "其他"}
          ]
        }
      },
      "payload_template": {
        "mode": "write_full_song",
        "prompt": "{theme}",
        "title": ""
      },
      "next_steps": [
        {
          "capability_id": "music-gen",
          "label": "用这段歌词生成音乐",
          "note": "额度敏感能力，需确认后执行",
          "blocked": false,
          "guarded": true,
          "handoff": {
            "lyrics": "$result.lyrics_or_text"
          }
        }
      ]
    },
    "tts-sync": {
      "capability_id": "tts-sync",
      "label": "短文本语音合成",
      "description": "输入文本，选择模型和音色，生成可播放音频。",
      "suitable_for": ["短视频旁白", "语音助手", "情绪对话", "有声书片段"],
      "risk_level": "safe",
      "result_type": "audio",
      "form_schema": {
        "text": {
          "type": "textarea",
          "label": "文本",
          "default": "你好，这是 MiniMax Token Plan 语音合成能力测试。",
          "placeholder": "输入要合成的文本，建议 300 字以内",
          "max_chars": 10000
        },
        "model": {
          "type": "select",
          "label": "模型",
          "default": "speech-2.8-hd",
          "options": [
            {"value": "speech-2.8-hd", "label": "speech-2.8-hd 官方当前·高质量"},
            {"value": "speech-2.8-turbo", "label": "speech-2.8-turbo 官方当前·低延迟"},
            {"value": "speech-02-hd", "label": "speech-02-hd 已验收稳定"},
            {"value": "speech-02-turbo", "label": "speech-02-turbo 已验收稳定"}
          ]
        },
        "voice_id": {
          "type": "input",
          "label": "音色 ID",
          "default": "",
          "placeholder": "先在「音色列表」查询可用 voice_id"
        },
        "speed": {
          "type": "number",
          "label": "语速",
          "default": "1.0",
          "placeholder": "范围 0.5~2.0",
          "value_type": "number",
          "min": 0.5,
          "max": 2.0,
          "step": 0.1
        }
      },
      "payload_template": {
        "model": "{model}",
        "text": "{text}",
        "voice_setting": {
          "voice_id": "{voice_id}",
          "speed": "{speed}"
        }
      },
      "next_steps": []
    },
    "voice-list": {
      "capability_id": "voice-list",
      "label": "查询音色列表",
      "description": "查询当前可用 voice_id，用于 TTS 语音合成。",
      "suitable_for": ["查询可用音色", "选择 TTS 音色"],
      "risk_level": "safe",
      "result_type": "voice_list",
      "form_schema": {},
      "payload_template": {},
      "next_steps": [
        {
          "capability_id": "tts-sync",
          "label": "语音合成",
          "note": "获取 voice_id 后可进入语音合成",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "voice_id": "$result.voice_id"
          }
        }
      ]
    },
    "tts-async": {
      "capability_id": "tts-async",
      "label": "异步语音合成",
      "description": "提交较长文本语音合成任务，获得 task_id 后可查询结果。",
      "suitable_for": ["长文本旁白", "有声书片段", "批量语音草稿"],
      "risk_level": "guarded",
      "result_type": "async_task",
      "form_schema": {
        "mode": {
          "type": "select",
          "label": "操作模式",
          "default": "start",
          "options": [
            {"value": "start", "label": "提交任务"},
            {"value": "query", "label": "查询任务结果"}
          ]
        },
        "task_id": {
          "type": "input",
          "label": "task_id",
          "default": "",
          "placeholder": "查询模式需要填写；提交任务成功后可自动带入"
        },
        "text": {
          "type": "textarea",
          "label": "文本",
          "default": "你好，这是 MiniMax 异步语音合成任务测试。",
          "placeholder": "输入要合成的长文本，建议 5000 字以内",
          "max_chars": 5000
        },
        "model": {
          "type": "select",
          "label": "模型",
          "default": "speech-2.8-hd",
          "options": [
            {"value": "speech-2.8-hd", "label": "speech-2.8-hd 高质量"},
            {"value": "speech-2.8-turbo", "label": "speech-2.8-turbo 低延迟"},
            {"value": "speech-02-hd", "label": "speech-02-hd 已验收稳定"},
            {"value": "speech-02-turbo", "label": "speech-02-turbo 已验收稳定"}
          ]
        },
        "voice_id": {
          "type": "input",
          "label": "音色 ID",
          "default": "",
          "placeholder": "可先使用 voice-list 查询 voice_id"
        },
        "speed": {
          "type": "number",
          "label": "语速",
          "default": "1.0",
          "placeholder": "范围 0.5~2.0",
          "value_type": "number",
          "min": 0.5,
          "max": 2.0,
          "step": 0.1
        },
        "confirm_long_task": {
          "type": "checkbox",
          "label": "我确认提交异步任务，可能需要稍后查询结果",
          "default": "false",
          "value_type": "boolean"
        }
      },
      "payload_template": {
        "mode": "{mode}",
        "task_id": "{task_id}",
        "model": "{model}",
        "text": "{text}",
        "voice_setting": {
          "voice_id": "{voice_id}",
          "speed": "{speed}"
        },
        "confirm_long_task": "{confirm_long_task}"
      },
      "next_steps": [
        {
          "capability_id": "tts-async",
          "label": "查询任务结果",
          "note": "提交成功后带入 task_id 查询结果",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "mode": "query",
            "task_id": "$result.task_id"
          }
        }
      ]
    },
    "image-t2i": {
      "capability_id": "image-t2i",
      "label": "文生图",
      "description": "输入 prompt，选择图片模型，生成图片。",
      "suitable_for": ["封面", "海报", "情绪 MV 分镜", "产品配图", "设计灵感"],
      "risk_level": "safe",
      "result_type": "image",
      "form_schema": {
        "prompt": {
          "type": "textarea",
          "label": "图片描述",
          "default": "一只橘猫坐在窗边，清晨阳光，真实摄影风格",
          "placeholder": "描述想要的图片内容",
          "max_chars": 1500
        },
        "model": {
          "type": "select",
          "label": "模型",
          "default": "image-01",
          "options": [
            {"value": "image-01", "label": "image-01 官方主力·支持尺寸控制"},
            {"value": "image-01-live", "label": "image-01-live 官方当前·画风控制"}
          ]
        },
        "aspect_ratio": {
          "type": "select",
          "label": "尺寸/比例",
          "default": "1:1",
          "options": [
            {"value": "1:1", "label": "1:1 方形"},
            {"value": "16:9", "label": "16:9 宽屏"},
            {"value": "9:16", "label": "9:16 竖屏"}
          ]
        }
      },
      "payload_template": {
        "model": "{model}",
        "prompt": "{prompt}",
        "aspect_ratio": "{aspect_ratio}"
      },
      "next_steps": [
        {
          "capability_id": "image-i2i",
          "label": "用此图片做图生图",
          "note": "需确认参考图片来源合法",
          "blocked": false,
          "guarded": true,
          "handoff": {
            "img_url": "$result.image_url"
          }
        }
      ]
    },
    "chat-openai": {
      "capability_id": "chat-openai",
      "label": "文本对话",
      "description": "使用 OpenAI 兼容协议测试 MiniMax 对话模型。",
      "suitable_for": ["问答", "对话测试", "SDK 接入验证"],
      "risk_level": "safe",
      "result_type": "chat",
      "form_schema": {
        "model": {
          "type": "select",
          "label": "模型",
          "default": "MiniMax-M2.7-highspeed",
          "options": [
            {"value": "MiniMax-M3", "label": "MiniMax-M3 官方主推·多模态旗舰"},
            {"value": "MiniMax-M2.7-highspeed", "label": "MiniMax-M2.7-highspeed Token Plan 高频"},
            {"value": "MiniMax-M2.7", "label": "MiniMax-M2.7 标准档"}
          ]
        },
        "prompt": {
          "type": "textarea",
          "label": "问题",
          "default": "请用一句话介绍 MiniMax Token Plan 的能力。",
          "placeholder": "输入你想问的问题"
        }
      },
      "payload_template": {
        "model": "{model}",
        "messages": [
          {"role": "user", "content": "{prompt}"}
        ],
        "max_tokens": 1024,
        "temperature": 0.7
      },
      "next_steps": []
    },
    "chat-anthropic": {
      "capability_id": "chat-anthropic",
      "label": "Anthropic 兼容对话",
      "description": "使用 Anthropic Messages 兼容协议测试 MiniMax 对话模型。",
      "suitable_for": ["Claude SDK 兼容验证", "Messages 协议测试", "对话问答"],
      "risk_level": "safe",
      "result_type": "chat",
      "form_schema": {
        "model": {
          "type": "select",
          "label": "模型",
          "default": "MiniMax-M2.7-highspeed",
          "options": [
            {"value": "MiniMax-M3", "label": "MiniMax-M3 官方主推"},
            {"value": "MiniMax-M2.7-highspeed", "label": "MiniMax-M2.7-highspeed Token Plan 高频"},
            {"value": "MiniMax-M2.7", "label": "MiniMax-M2.7 标准档"}
          ]
        },
        "prompt": {
          "type": "textarea",
          "label": "问题",
          "default": "请用一句话介绍 MiniMax 的 Anthropic 兼容协议。",
          "placeholder": "输入你想问的问题",
          "max_chars": 4000
        },
        "max_tokens": {
          "type": "number",
          "label": "max_tokens",
          "default": "1024",
          "value_type": "number",
          "min": 1,
          "max": 4096,
          "step": 1
        }
      },
      "payload_template": {
        "model": "{model}",
        "max_tokens": "{max_tokens}",
        "messages": [
          {"role": "user", "content": "{prompt}"}
        ],
        "stream": false
      },
      "next_steps": []
    },
    "chat-responses-create": {
      "capability_id": "chat-responses-create",
      "label": "Responses 对话",
      "description": "使用 OpenAI Responses 兼容协议测试 MiniMax 响应生成。",
      "suitable_for": ["Responses API 接入验证", "OpenAI SDK 兼容验证", "文本生成"],
      "risk_level": "safe",
      "result_type": "chat",
      "form_schema": {
        "model": {
          "type": "select",
          "label": "模型",
          "default": "MiniMax-M2.7-highspeed",
          "options": [
            {"value": "MiniMax-M3", "label": "MiniMax-M3 官方主推"},
            {"value": "MiniMax-M2.7-highspeed", "label": "MiniMax-M2.7-highspeed Token Plan 高频"},
            {"value": "MiniMax-M2.7", "label": "MiniMax-M2.7 标准档"}
          ]
        },
        "prompt": {
          "type": "textarea",
          "label": "问题",
          "default": "请用一句话介绍 MiniMax 的 Responses 兼容协议。",
          "placeholder": "输入你想生成的内容",
          "max_chars": 4000
        },
        "max_output_tokens": {
          "type": "number",
          "label": "max_output_tokens",
          "default": "1024",
          "value_type": "number",
          "min": 1,
          "max": 4096,
          "step": 1
        }
      },
      "payload_template": {
        "model": "{model}",
        "input": "{prompt}",
        "max_output_tokens": "{max_output_tokens}",
        "stream": false
      },
      "next_steps": []
    },
    "music-gen": {
      "capability_id": "music-gen",
      "label": "音乐生成",
      "description": "使用歌词、风格和标题生成音乐音频。",
      "suitable_for": ["情绪 MV", "AI 歌曲草稿", "短视频 BGM"],
      "risk_level": "quota_sensitive",
      "result_type": "audio",
      "form_schema": {
        "lyrics": {
          "type": "textarea",
          "label": "歌词",
          "default": "",
          "placeholder": "可由 lyrics-gen 自动带入，或手动粘贴歌词"
        },
        "style": {
          "type": "input",
          "label": "音乐风格",
          "default": "温柔、怀旧、民谣",
          "placeholder": "如：流行、民谣、电子、摇滚"
        },
        "title": {
          "type": "input",
          "label": "歌曲标题",
          "default": "夏日晚风",
          "placeholder": "输入歌曲标题"
        },
        "model": {
          "type": "select",
          "label": "模型",
          "default": "music-2.6",
          "options": [
            {"value": "music-2.6", "label": "music-2.6 官方推荐·音乐生成"}
          ]
        },
        "confirm_quota": {
          "type": "checkbox",
          "label": "我确认该能力会消耗 Token Plan 额度",
          "default": "false",
          "value_type": "boolean"
        }
      },
      "payload_template": {
        "model": "{model}",
        "lyrics": "{lyrics}",
        "prompt": "{style}",
        "title": "{title}",
        "confirm_quota": "{confirm_quota}"
      },
      "next_steps": []
    },
    "image-i2i": {
      "capability_id": "image-i2i",
      "label": "图生图",
      "description": "基于参考图片生成新图片。当前不是严格局部编辑，主体一致性取决于模型理解。",
      "suitable_for": ["图像变体", "风格迁移", "封面二次创作"],
      "risk_level": "guarded",
      "result_type": "image",
      "form_schema": {
        "img_url": {
          "type": "input",
          "label": "参考图片 URL",
          "default": "",
          "placeholder": "可由 image-t2i 自动带入，或手动输入图片 URL"
        },
        "prompt": {
          "type": "textarea",
          "label": "修改描述",
          "default": "尽量保持参考图主体特征，增强电影感光影",
          "placeholder": "描述你想如何改变图片"
        },
        "reference_mode": {
          "type": "select",
          "label": "参考模式",
          "default": "subject",
          "options": [
            {"value": "subject", "label": "主体参考 / 尽量保持主体"},
            {"value": "style", "label": "风格参考 / 只参考画风"},
            {"value": "variation", "label": "参考图变体 / 允许较大变化"}
          ]
        },
        "model": {
          "type": "select",
          "label": "模型",
          "default": "image-01",
          "options": [
            {"value": "image-01", "label": "image-01 图生图主力"}
          ],
          "note": "当前图生图仅开放已验收的 image-01。image-01-live 是否支持图生图需要单独验证。"
        },
        "confirm_asset_source": {
          "type": "checkbox",
          "label": "我确认参考图片来源合法（原创或已获授权）",
          "default": "false",
          "value_type": "boolean"
        }
      },
      "payload_template": {
        "model": "{model}",
        "prompt": "{prompt}",
        "subject_reference": [
          {
            "type": "character",
            "image_file": "{img_url}"
          }
        ],
        "confirm_asset_source": "{confirm_asset_source}"
      },
      "next_steps": []
    },
    "file-upload": {
      "capability_id": "file-upload",
      "label": "文件上传",
      "description": "上传安全小文件，获取 file_id，可用于后续查询详情或读取内容。",
      "suitable_for": ["安全小文件存储", "知识库录入", "检索与内容读取"],
      "risk_level": "guarded",
      "result_type": "file_upload",
      "form_schema": {
        "file": {
          "type": "file",
          "label": "选择文件",
          "default": "",
          "placeholder": "支持 .txt / .md / .json / .csv 等安全小文件（最大 1MB）"
        },
        "purpose": {
          "type": "select",
          "label": "用途",
          "default": "retrieval",
          "options": [
            {"value": "retrieval", "label": "retrieval / 检索与内容读取"}
          ]
        },
        "confirm_asset_source": {
          "type": "checkbox",
          "label": "我确认上传文件来源合法且不包含敏感信息",
          "default": "false",
          "value_type": "boolean"
        }
      },
      "payload_template": {},
      "next_steps": [
        {
          "capability_id": "file-retrieve",
          "label": "查询文件详情",
          "note": "获取 file_id 后查询文件元信息",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "file_id": "$result.file_id"
          }
        },
        {
          "capability_id": "file-content",
          "label": "读取文件内容",
          "note": "获取 file_id 后读取文本内容",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "file_id": "$result.file_id"
          }
        }
      ]
    },
    "file-list": {
      "capability_id": "file-list",
      "label": "查询文件列表",
      "description": "查询当前已上传的文件列表，获取 file_id 后可查询详情或读取内容。",
      "suitable_for": ["查看已上传文件", "选择文件进入后续链路"],
      "risk_level": "safe",
      "result_type": "file_list",
      "form_schema": {
        "purpose": {
          "type": "select",
          "label": "文件用途",
          "default": "retrieval",
          "options": [
            {"value": "retrieval", "label": "retrieval / 检索与内容读取"},
            {"value": "all", "label": "全部"}
          ]
        }
      },
      "payload_template": {},
      "next_steps": [
        {
          "capability_id": "file-retrieve",
          "label": "查询文件详情",
          "note": "选择文件后查询详情",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "file_id": "$result.file_id"
          }
        },
        {
          "capability_id": "file-content",
          "label": "读取文件内容",
          "note": "选择文件后读取内容",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "file_id": "$result.file_id"
          }
        }
      ]
    },
    "file-retrieve": {
      "capability_id": "file-retrieve",
      "label": "查询文件详情",
      "description": "通过 file_id 查询文件元信息（filename、size、mime_type、创建时间等）。",
      "suitable_for": ["查看文件元信息", "确认文件是否上传成功"],
      "risk_level": "safe",
      "result_type": "file_detail",
      "form_schema": {
        "file_id": {
          "type": "input",
          "label": "file_id",
          "default": "",
          "placeholder": "上传后获得的 file_id"
        }
      },
      "payload_template": {
        "file_id": "{file_id}"
      },
      "next_steps": [
        {
          "capability_id": "file-content",
          "label": "读取文件内容",
          "note": "获取内容用于预览或处理",
          "blocked": false,
          "guarded": false,
          "handoff": {
            "file_id": "$result.file_id"
          }
        }
      ]
    },
    "file-content": {
      "capability_id": "file-content",
      "label": "读取文件内容",
      "description": "通过 file_id 读取文件文本内容（纯文本或 JSON 格式最多 3000 字预览）。",
      "suitable_for": ["预览文件内容", "验证上传内容是否正确"],
      "risk_level": "safe",
      "result_type": "file_content",
      "form_schema": {
        "file_id": {
          "type": "input",
          "label": "file_id",
          "default": "",
          "placeholder": "上传后获得的 file_id"
        }
      },
      "payload_template": {
        "file_id": "{file_id}"
      },
      "next_steps": []
    }
  }
}
