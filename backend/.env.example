# ============================================================
# MiniMax 凭证配置
# ============================================================
# 复制此文件为 .env 后填入真实值，前端不会读取这里的内容。
# 重要：.env 不得提交 Git（已写入 .gitignore）
# ============================================================

# ----------------------------------------------------------
# MiniMax Token Plan 订阅 Key（推荐）
# ----------------------------------------------------------
# 获取位置：MiniMax 开放平台 > 订阅管理 > Token Plan
# 用途：TokenPlanPlus / Token Plan 额度和已购积分（用于会员权益类 API）
# 适用范围：speech TTS、image、music 等 native 多模态能力
# 注意：
#   - 与普通按量 API Key 不互通
#   - 如果你有 TokenPlanPlus 会员权益，请优先配置此 Key
#   - 配置后可用 --key-source token-plan 验证 TokenPlan 权益
MINIMAX_TOKEN_PLAN_KEY=

# ----------------------------------------------------------
# MiniMax 普通开放平台 API Key
# ----------------------------------------------------------
# 获取位置：MiniMax 开放平台 > 账户管理 > 接口密钥
# 用途：按量计费 API 调用，消耗账户余额
# 适用范围：chat（OpenAI 协议）、Anthropic 协议、models-* 等能力
# 注意：
#   - 与 Token Plan 订阅 Key 不互通
#   - 如果 native 多模态返回 1004，可能是此 Key 无权限
MINIMAX_API_KEY=

# ----------------------------------------------------------
# Group ID（可选）
# ----------------------------------------------------------
# 用于区分不同应用/团队的用量，大多数情况下留空即可
MINIMAX_GROUP_ID=

# ----------------------------------------------------------
# Base URL（通常不需要修改）
# ----------------------------------------------------------
# 国内站：https://api.minimaxi.com
# 海外站：https://api.minimax.io
MINIMAX_BASE_URL=https://api.minimaxi.com

# ----------------------------------------------------------
# CORS 放行（前端开发用）
# ----------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# ============================================================
# 配置建议
# ============================================================
# 1. 如果你要验证 TokenPlanPlus 会员权益（speech/image/music 等 native 能力）：
#    → 配置 MINIMAX_TOKEN_PLAN_KEY
#    → 运行：python scripts/probe_model_level_support.py --scope low-cost --native-only --key-source token-plan
#
# 2. 如果你要验证 chat / models-* 等按量计费能力：
#    → 配置 MINIMAX_API_KEY
#    → 运行：python scripts/probe_model_level_support.py --scope low-cost
#
# 3. 1004 错误 ≠ 模型不可用
#    → 1004 表示 Token/鉴权问题，可能是 Key 类型不对或账户欠费
#    → 确认使用的是正确的 Key 类型（TokenPlan vs 按量 API）
# ============================================================
