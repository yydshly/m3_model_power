# ============================================================
# MiniMax 凭证配置
# ============================================================
# 复制此文件为 .env 后填入真实值，前端不会读取这里的内容。
# 重要：.env 不得提交 Git（已写入 .gitignore）
# ============================================================

# ============================================================
# Token Plan Only 模式（默认）
# ============================================================
# 本项目默认只验证 TokenPlanPlus 极速版能力。
# MINIMAX_TOKEN_PLAN_KEY 是唯一参与验收的凭证。
# ============================================================

# ----------------------------------------------------------
# MiniMax Token Plan 订阅 Key（必填）
# ----------------------------------------------------------
# 获取位置：MiniMax 开放平台 > 订阅管理 > Token Plan
# 用途：TokenPlanPlus 极速版套餐能力验收（speech / image / music / lyrics 等 native 多模态）
# 注意：
#   - Token Plan Key 是本项目的默认验收凭证
#   - 不与普通按量 API Key 互换
#   - 如果未配置，项目将跳过 native 多模态验收
MINIMAX_TOKEN_PLAN_KEY=

# ----------------------------------------------------------
# MiniMax 普通按量 API Key（仅用于可选诊断）
# ----------------------------------------------------------
# 获取位置：MiniMax 开放平台 > 账户管理 > 接口密钥
# 用途：仅在显式传递 --key-source api-key 时用于对照诊断
# 注意：
#   - 不参与本项目的默认验收
#   - 普通 API Key 无法访问 native 多模态权益（会返回 1004）
#   - 如无特殊需要，无需配置
# MINIMAX_API_KEY=

# ----------------------------------------------------------
# Group ID（可选）
# ----------------------------------------------------------
# 用于区分不同应用/团队的用量，大多数情况下留空即可
MINIMAX_GROUP_ID=

# ----------------------------------------------------------
# Base URL（通常不需要修改）
# ----------------------------------------------------------
# 国内站：https://api.minimaxi.com
# 海外站：https://api.minimax.io
MINIMAX_BASE_URL=https://api.minimaxi.com

# ----------------------------------------------------------
# CORS 放行（前端开发用）
# ----------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# ============================================================
# 快速开始
# ============================================================
# 1. 配置 TokenPlan Key：
#    → 在 backend/.env 中设置 MINIMAX_TOKEN_PLAN_KEY
#
# 2. 运行能力验收：
#    → python scripts/verify_minimax_capabilities.py --level medium --confirm-cost
#    → python scripts/probe_model_level_support.py --scope low-cost
#
# 3. HTTP 200 ≠ 业务成功
#    → 必须检查 base_resp.status_code
#    → 1004 = 鉴权/Token 问题，非模型不可用
# ============================================================
